// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "relationJoins", "nativeDistinct"]
}

enum Role {
  USER
  ADMIN
}

enum FormType {
  DYNAMIC
  STATIC
}

model User {
  id         String  @id @default(cuid())
  externalId String  @unique
  name       String?
  email      String? @unique
  image      String?

  forms     FormOnUsers[]
  role      Role          @default(ADMIN)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([email, name, externalId])
}

model Form {
  id           String        @id() @unique() @default(cuid())
  name         String
  type         FormType      @default(STATIC)
  isEnabled    Boolean       @default(true)
  hasRetention Boolean       @default(true)
  redirectUrl  String?
  createdAt    DateTime?     @default(now())
  updatedAt    DateTime?     @updatedAt
  users        FormOnUsers[]
  Submission   Submission[]

  @@index([name])
}

model FormOnUsers {
  formId    String
  userId    String
  role      Role      @default(ADMIN)
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  user User @relation(fields: [userId], references: [externalId])
  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@id([formId, userId])
  @@unique([formId, userId])
  @@index([formId])
}

model Submission {
  id        String   @id() @unique() @default(cuid())
  formId    String
  isSpam    Boolean  @default(false)
  viewed    Boolean  @default(false)
  data      Json
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  form Form @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
}
